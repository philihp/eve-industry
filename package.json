{
  "name": "eve-industry",
  "version": "0.1.0",
  "description": "EVE Online Industry Calculations",
  "homepage": "https://github.com/philihp/eve-industry",
  "repository": "https://github.com/philihp/eve-industry.git",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "/dist/",
    "!/dist/**/__tests__/*.*"
  ],
  "sideEffects": false,
  "keywords": [
    "eveonline",
    "industry"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "build:clean": "rm -rf dist",
    "format": "prettier --write .",
    "lint": "eslint src",
    "prepare": "husky",
    "test": "node --test --test-reporter=spec 'src/**/*.test.ts'",
    "test:watch": "node --test --watch --test-reporter=spec 'src/**/*.test.ts'"
  },
  "author": "Philihp Busby <philihp@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "trailingComma": "es5"
  }
}
