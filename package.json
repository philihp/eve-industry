{
  "name": "eve-industry",
  "version": "0.1.0",
  "description": "EVE Online Industry Calculations",
  "homepage": "https://github.com/philihp/eve-industry",
  "repository": "https://github.com/philihp/eve-industry.git",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "/dist/",
    "!/dist/**/__tests__/*.*"
  ],
  "sideEffects": false,
  "keywords": [
    "eveonline",
    "industry"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "lint": "eslint src",
    "prepare": "husky && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Philihp Busby <philihp@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@philihp/eslint-config": "6.1.0",
    "@tsconfig/node22": "22.0.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json}": [
      "eslint --fix"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "trailingComma": "es5"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "plugin:@typescript-eslint/recommended",
      "@philihp"
    ],
    "rules": {
      "import/no-unresolved": "off"
    }
  }
}
