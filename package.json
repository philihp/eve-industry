{
  "name": "eve-industry",
  "version": "0.1.0",
  "description": "EVE Online Industry Calculations",
  "homepage": "https://github.com/philihp/eve-industry",
  "repository": "https://github.com/philihp/eve-industry.git",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "/dist/",
    "!/dist/**/__tests__/*.*"
  ],
  "sideEffects": false,
  "keywords": [
    "eveonline",
    "industry"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "lint": "eslint src",
    "prepare": "husky && npm run build",
    "test": "node --test --test-reporter=spec 'src/**/*.test.ts'",
    "test:watch": "node --test --watch --test-reporter=spec 'src/**/*.test.ts'"
  },
  "author": "Philihp Busby <philihp@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@tsconfig/node22": "22.0.2",
    "eslint": "9.16.0",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "prettier": "3.4.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "trailingComma": "es5"
  }
}
